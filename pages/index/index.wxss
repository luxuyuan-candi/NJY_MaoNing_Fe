.home-page {
  background: #f7f4ef;
  height: 100vh;
  padding: 0;
  overflow: hidden;
}

.home-stage {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.home-reference {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.video-shell,
.video-tabs {
  position: absolute;
  z-index: 2;
}

.video-shell {
  left: 38.5%;
  top: 59.8%;
  width: 54.8%;
  height: 14.6%;
  border-radius: 28rpx;
  overflow: hidden;
}

.feature-video {
  width: 100%;
  height: 100%;
  background: #111111;
}

.video-tabs {
  left: 5%;
  top: 75.6%;
  width: 90%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.video-tab {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 248, 0.92);
  color: #6d665d;
  font-size: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(67, 49, 28, 0.08);
}

.video-tab-active {
  background: #6f8a52;
  color: #ffffff;
}

