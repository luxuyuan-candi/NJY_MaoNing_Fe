.home-page {
  background:
    radial-gradient(circle at top left, rgba(239, 229, 214, 0.9), transparent 34%),
    linear-gradient(180deg, #f7f4ef 0%, #f4efe8 100%);
  display: flex;
  align-items: center;
}

.home-hero {
  width: 100%;
  padding: 24rpx;
}

.video-swiper {
  width: 100%;
  height: 70vh;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e7ddd2;
}

.swiper-video {
  width: 100%;
  height: 100%;
}

