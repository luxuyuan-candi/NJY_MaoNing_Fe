.home-page {
  background:
    radial-gradient(circle at top left, rgba(239, 229, 214, 0.9), transparent 34%),
    linear-gradient(180deg, #f7f4ef 0%, #f4efe8 100%);
}

.home-hero {
  padding: 34rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-tag {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #efe5d6;
  color: #866f5c;
  font-size: 22rpx;
}

.video-swiper {
  width: 100%;
  height: 380rpx;
  margin-top: 28rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #e7ddd2;
}

.swiper-video {
  width: 100%;
  height: 100%;
}

.intro-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.section-head {
  display: flex;
  flex-direction: column;
}

.feature-list {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0e7dc;
}

.feature-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.feature-title,
.quick-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2e2a26;
}

.feature-desc,
.quick-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7f7267;
}

.quick-grid {
  margin-top: 24rpx;
  display: grid;
  gap: 18rpx;
}

.quick-card {
  padding: 28rpx 30rpx;
  text-align: left;
}

.home-footer {
  margin-top: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: #9b8d80;
}

