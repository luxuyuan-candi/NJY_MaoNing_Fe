.home-page {
  background: #f7f4ef;
}

.home-stage {
  position: relative;
  width: 100%;
  height: 0;
  padding-top: 162.77%;
  overflow: hidden;
}

.home-reference {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.video-shell,
.video-tabs,
.stats-overlay {
  position: absolute;
  z-index: 2;
}

.video-shell {
  left: 4%;
  top: 54.2%;
  width: 90.6%;
  height: 17.4%;
  border-radius: 28rpx;
  overflow: hidden;
}

.feature-video {
  width: 100%;
  height: 100%;
  background: #111111;
}

.video-tabs {
  left: 5%;
  top: 70.7%;
  width: 90%;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.video-tab {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 248, 0.92);
  color: #6d665d;
  font-size: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(67, 49, 28, 0.08);
}

.video-tab-active {
  background: #6f8a52;
  color: #ffffff;
}

.stats-overlay {
  left: 4.2%;
  top: 77%;
  width: 74.5%;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  justify-content: center;
  min-width: 0;
}

.stats-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.stats-value {
  font-size: 44rpx;
  line-height: 1;
  font-weight: 700;
  color: #48633d;
}

.stats-unit {
  font-size: 24rpx;
  color: #6f665d;
}

