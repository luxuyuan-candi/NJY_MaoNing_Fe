<view class="page-shell home-page">
  <view class="hero-card home-hero">
    <swiper
      class="video-swiper"
      circular
      indicator-dots
      interval="{{swiperInterval}}"
      duration="500"
    >
      <block wx:for="{{videoList}}" wx:key="index">
        <swiper-item>
          <video
            class="swiper-video"
            src="{{item.src}}"
            controls
            autoplay
            muted
            loop
            objectFit="cover"
            bindplay="onVideoPlay"
            bindended="onVideoEnded"
          ></video>
        </swiper-item>
      </block>
    </swiper>
  </view>
</view>
