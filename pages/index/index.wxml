<view class="page-shell home-page">
  <view class="hero-card home-hero">
    <view class="hero-copy">
      <text class="hero-tag">猫宁平台</text>
      <text class="section-title">校园环保与爱宠服务</text>
      <text class="section-subtitle">围绕药渣回收、猫砂流转和试用申请，提供统一的小程序入口。</text>
    </view>

    <swiper
      class="video-swiper"
      circular
      indicator-dots
      interval="{{swiperInterval}}"
      duration="500"
    >
      <block wx:for="{{videoList}}" wx:key="index">
        <swiper-item>
          <video
            class="swiper-video"
            src="{{item.src}}"
            controls
            objectFit="cover"
            bindplay="onVideoPlay"
            bindended="onVideoEnded"
          ></video>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view class="section-card intro-card">
    <view class="section-head">
      <text class="section-title">功能概览</text>
      <text class="section-subtitle">简洁的四栏结构，分别承载首页、药渣、猫砂和个人信息。</text>
    </view>
    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-title">首页宣传视频</text>
        <text class="feature-desc">轮播展示项目内容和平台介绍。</text>
      </view>
      <view class="feature-item">
        <text class="feature-title">药渣回收</text>
        <text class="feature-desc">查看回收记录、分类筛选和统计入口。</text>
      </view>
      <view class="feature-item">
        <text class="feature-title">猫砂服务</text>
        <text class="feature-desc">统一收纳出售与试用两个业务模块。</text>
      </view>
    </view>
  </view>

  <view class="quick-grid">
    <button class="section-card quick-card" bindtap="goToYaoZha">
      <text class="quick-title">进入药渣</text>
      <text class="quick-desc">回收记录与单位统计</text>
    </button>
    <button class="section-card quick-card" bindtap="goToMaoSha">
      <text class="quick-title">进入猫砂</text>
      <text class="quick-desc">出售与试用整合入口</text>
    </button>
    <button class="section-card quick-card" bindtap="goToProfile">
      <text class="quick-title">进入个人</text>
      <text class="quick-desc">维护登录和联系方式</text>
    </button>
  </view>

  <view class="home-footer">本平台由内江市卫生与健康职业学院维护提供服务。</view>
</view>
