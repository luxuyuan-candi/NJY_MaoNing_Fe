<view class="page-shell detail-page">
  <view class="detail-hero">
    <view class="hero-left">
      <view class="hero-badge">
        <image
          class="hero-badge-icon"
          src="{{form.type === 'person' ? '../../images/yaozha/entity-person.png' : '../../images/yaozha/entity-company.png'}}"
          mode="aspectFit"
        ></image>
      </view>
      <view class="hero-copy">
        <text class="hero-name">{{form.unit}}</text>
        <view class="hero-status {{form.status === '已回收' ? 'hero-status-finish' : 'hero-status-pending'}}">
          {{form.status}}
        </view>
      </view>
    </view>
    <image class="hero-image" src="../../images/yaozha/hero-illustration.jpg" mode="aspectFit"></image>
  </view>

  <view class="detail-card">
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="{{form.type === 'person' ? '../../images/yaozha/entity-person.png' : '../../images/yaozha/entity-company.png'}}" mode="aspectFit"></image>
      </view>
      <text class="detail-label">{{form.unitLabel}}</text>
      <text class="detail-value">{{form.unit}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/entity-person.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">联系人</text>
      <text class="detail-value">{{form.contact}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/summary-filter.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">地址</text>
      <text class="detail-value detail-value-wide">{{form.location}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/summary-record.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">预约时间</text>
      <text class="detail-value">{{form.date}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/summary-record.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">批号</text>
      <text class="detail-value">{{form.batch_no || '无'}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/action-add.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">药材重量</text>
      <text class="detail-value">{{form.weight}}kg</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/action-stats.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">核准重量</text>
      <text class="detail-value">{{form.approved_weight ? form.approved_weight + 'kg' : '未核准'}}</text>
    </view>
    <view class="detail-row">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/title-leaf.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">药材种类</text>
      <text class="detail-value detail-value-wide">{{form.herbs}}</text>
    </view>
    <view class="detail-row detail-row-last">
      <view class="detail-icon-wrap">
        <image class="detail-icon" src="../../images/yaozha/summary-record.png" mode="aspectFit"></image>
      </view>
      <text class="detail-label">状态</text>
      <text class="detail-value">{{form.status}}</text>
    </view>
  </view>

  <button wx:if="{{form.status === '待处理'}}" class="finish-btn" bindtap="markAsFinished">
    <view class="finish-btn-inner">
      <view class="finish-btn-icon">
        <image class="finish-btn-image" src="../../images/yaozha/action-add.png" mode="aspectFit"></image>
      </view>
      <view class="finish-btn-copy">
        <text class="finish-btn-title">确认回收</text>
        <text class="finish-btn-subtitle">填写核准重量与批号</text>
      </view>
    </view>
  </button>

  <view class="tips-card">
    <text class="tips-title">温馨提示</text>
    <text class="tips-text">感谢您对中药渣回收的支持，绿色环保，从你我做起。</text>
  </view>

  <view wx:if="{{showModal}}" class="modal-overlay">
    <view class="modal-content">
      <view class="modal-head">
        <view class="modal-head-icon">
          <image class="modal-head-image" src="../../images/yaozha/action-add.png" mode="aspectFit"></image>
        </view>
        <view class="modal-head-copy">
          <text class="modal-main-title">确认回收</text>
          <text class="modal-subtitle">补充核准信息后完成本次回收</text>
        </view>
      </view>

      <view class="modal-field">
        <text class="modal-title">核准重量</text>
        <input type="number" placeholder="如：2.5" bindinput="onInputWeight" value="{{inputWeight}}" class="modal-input"/>
      </view>

      <view class="modal-field">
        <text class="modal-title">批号</text>
        <input type="text" placeholder="如：20250726PT-1" bindinput="onInputBatchNo" value="{{inputBatchNo}}" class="modal-input"/>
      </view>

      <view class="modal-buttons">
        <button bindtap="onCancel" class="modal-btn cancel">
          <view class="modal-btn-inner">
            <text class="modal-btn-text cancel-text">取消</text>
          </view>
        </button>
        <button type="primary" bindtap="onConfirm" class="modal-btn confirm">
          <view class="modal-btn-inner">
            <text class="modal-btn-text confirm-text">确定</text>
          </view>
        </button>
      </view>
    </view>
  </view>
</view>
