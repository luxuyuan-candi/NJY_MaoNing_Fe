page {
  background:
    radial-gradient(circle at top right, rgba(240, 235, 220, 0.68), transparent 28%),
    radial-gradient(circle at top left, rgba(225, 238, 226, 0.9), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f3efe6 100%);
}

.detail-page {
  min-height: 100vh;
}

.detail-hero,
.detail-card,
.tips-card {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid #ecf0e8;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 44rpx rgba(61, 52, 40, 0.06);
}

.detail-hero {
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
  flex: 1;
  min-width: 0;
}

.hero-badge {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #edf4ea;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-badge-icon {
  width: 64rpx;
  height: 64rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1e5f39;
  word-break: break-all;
}

.hero-status {
  margin-top: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 170rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
}

.hero-status-finish {
  color: #438a57;
  background: #edf6ee;
  border: 2rpx solid #9fd0aa;
}

.hero-status-pending {
  color: #af7a3a;
  background: #fbf1e3;
  border: 2rpx solid #e7c691;
}

.hero-image {
  width: 260rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.detail-card {
  margin-top: 24rpx;
  padding: 12rpx 28rpx;
}

.detail-row {
  min-height: 124rpx;
  display: grid;
  grid-template-columns: 78rpx 200rpx 1fr;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx dashed #dce6d9;
}

.detail-row-last {
  border-bottom: none;
}

.detail-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #edf5ec;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-icon {
  width: 34rpx;
  height: 34rpx;
}

.detail-label {
  font-size: 27rpx;
  font-weight: 600;
  color: #4f5c53;
}

.detail-value {
  font-size: 28rpx;
  color: #1f1f1f;
  text-align: left;
  word-break: break-all;
}

.detail-value-wide {
  line-height: 1.45;
}

.finish-btn {
  margin-top: 24rpx;
  height: 110rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #eef5ec 0%, #e2ede0 100%);
  border: 2rpx solid #bdd3be;
  color: #2c6f3f;
  box-shadow: 0 14rpx 28rpx rgba(81, 112, 76, 0.08);
}

.finish-btn::after {
  border: none;
}

.finish-btn-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.finish-btn-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.finish-btn-image {
  width: 34rpx;
  height: 34rpx;
}

.finish-btn-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.finish-btn-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c6f3f;
}

.finish-btn-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6d7c70;
}

.tips-card {
  margin-top: 24rpx;
  padding: 26rpx 30rpx;
  background: linear-gradient(180deg, rgba(244, 249, 241, 0.9) 0%, rgba(235, 244, 232, 0.95) 100%);
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f7a3b;
}

.tips-text {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4f5f53;
}

.modal-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(180deg, #fffefc 0%, #f8f5ee 100%);
  padding: 30rpx;
  border-radius: 30rpx;
  width: 82%;
  text-align: left;
  box-shadow: 0 24rpx 60rpx rgba(30, 30, 30, 0.16);
}

.modal-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.modal-head-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #edf5ec;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.modal-head-image {
  width: 42rpx;
  height: 42rpx;
}

.modal-head-copy {
  min-width: 0;
}

.modal-main-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #255d38;
}

.modal-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #68756a;
}

.modal-field {
  margin-bottom: 20rpx;
}

.modal-title {
  display: block;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  font-weight: 600;
  color: #435147;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  border: 1px solid #d7ddd6;
  border-radius: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  background: #fbfcfa;
  font-size: 26rpx;
  color: #2f312d;
}

.modal-buttons {
  display: flex;
  gap: 18rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 22rpx;
  padding: 0;
}

.modal-btn.cancel {
  background: linear-gradient(180deg, #f5f7f4 0%, #e9eeea 100%);
  color: #33413a;
  border: 1rpx solid #d5ddd5;
}

.modal-btn.confirm {
  background: linear-gradient(180deg, #4d8f5f 0%, #39774b 100%);
  color: white;
  box-shadow: 0 12rpx 24rpx rgba(57, 119, 75, 0.18);
}

.modal-btn::after {
  border: none;
}

.modal-btn-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.cancel-text {
  color: #3f4c43;
}

.confirm-text {
  color: #ffffff;
}
