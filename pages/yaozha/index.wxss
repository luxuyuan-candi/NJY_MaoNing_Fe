.recycle-page {
  background:
    radial-gradient(circle at top right, rgba(240, 235, 220, 0.7), transparent 28%),
    radial-gradient(circle at top left, rgba(225, 238, 226, 0.9), transparent 34%),
    linear-gradient(180deg, #f8f5ef 0%, #f2eee5 100%);
}

.recycle-hero {
  padding: 32rpx;
}

.hero-main {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  padding-top: 28rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
}

.hero-title {
  font-size: 64rpx;
  line-height: 1.05;
  font-weight: 700;
  color: #1f5f3a;
}

.hero-illustration {
  width: 288rpx;
  height: 236rpx;
  flex-shrink: 0;
}

.hero-illustration-image {
  width: 100%;
  height: 100%;
}

.summary-strip {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.summary-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #eef4ed 0%, #f6f8f3 100%);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.summary-item-warm {
  background: linear-gradient(180deg, #fbefdf 0%, #fff7ee 100%);
}

.summary-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #418353;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: inset 0 0 0 6rpx rgba(232, 241, 230, 0.9);
}

.circle-icon {
  width: 56rpx;
  height: 56rpx;
}

.summary-icon-warm {
  color: #e39a2f;
  box-shadow: inset 0 0 0 6rpx rgba(255, 244, 228, 0.95);
}

.summary-copy {
  flex: 1;
}

.summary-value,
.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2e2a26;
}

.summary-label,
.info-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #54695b;
}

.filter-panel {
  margin-top: 22rpx;
  padding: 10rpx;
}

.filter-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.filter-tab {
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #37312c;
}

.filter-tab-active {
  background: #438a57;
  color: #ffffff;
  font-weight: 600;
}

.action-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.soft-action {
  border: 2rpx solid transparent;
}

.soft-action-sage {
  border-color: #a6b9b0;
  background: linear-gradient(180deg, #f7fbfa 0%, #edf4f2 100%);
}

.soft-action-sand {
  border-color: #ddc6a8;
  background: linear-gradient(180deg, #fffaf2 0%, #f7ecde 100%);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e9f1f0;
  color: #5a7f73;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.action-icon-light {
  background: #f6ede1;
  color: #9a6637;
  border: 2rpx solid rgba(214, 184, 149, 0.45);
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #536f69;
}

.recycle-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recycle-card {
  padding: 24rpx 24rpx 18rpx;
  position: relative;
  overflow: hidden;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.card-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #edf5ea;
  color: #438a57;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.status-chip {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-success {
  background: #e3f1e8;
  color: #3f7f56;
}

.status-pending {
  background: #f6ead7;
  color: #a56f33;
}

.info-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx 16rpx;
}

.info-item {
  min-width: 0;
}

.info-item-wide {
  grid-column: span 2;
}

.info-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-icon-wrap {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #eef5ec;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.info-icon {
  width: 24rpx;
  height: 24rpx;
}

.info-value {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #2f312d;
  line-height: 1.45;
  word-break: break-all;
}

.card-landscape {
  position: absolute;
  right: -10rpx;
  bottom: -12rpx;
  width: 220rpx;
  height: 84rpx;
  background:
    radial-gradient(circle at 85% 70%, rgba(121, 170, 98, 0.2), transparent 18%),
    radial-gradient(circle at 74% 58%, rgba(219, 238, 211, 0.55), transparent 24%),
    linear-gradient(180deg, rgba(236, 244, 229, 0) 0%, rgba(219, 238, 211, 0.95) 100%);
  border-radius: 120rpx 0 24rpx 0;
  pointer-events: none;
}
