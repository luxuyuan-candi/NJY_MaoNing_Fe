.recycle-page {
  background:
    radial-gradient(circle at top right, rgba(230, 239, 233, 0.85), transparent 30%),
    linear-gradient(180deg, #f7f4ef 0%, #f5efe7 100%);
}

.recycle-hero {
  padding: 32rpx;
}

.summary-strip {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.summary-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f8f5f0;
}

.summary-value,
.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2e2a26;
}

.summary-label,
.info-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b7b6f;
}

.recycle-filters {
  margin-top: 22rpx;
}

.action-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
}

.recycle-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.recycle-card {
  padding: 28rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.status-chip {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-success {
  background: #e3f1e8;
  color: #3f7f56;
}

.status-pending {
  background: #f6ead7;
  color: #a56f33;
}

.info-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx 16rpx;
}

.info-item {
  min-width: 0;
}

.info-item-wide {
  grid-column: span 2;
}

.info-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #4b433c;
  word-break: break-all;
}
