<view class="page-shell recycle-page">
  <view class="hero-card recycle-hero">
    <view class="hero-main">
      <view class="hero-copy">
        <view class="hero-title-row">
          <text class="hero-title">药渣回收</text>
        </view>
      </view>
      <view class="hero-illustration">
        <image class="hero-illustration-image" src="../../images/yaozha/hero-illustration.png" mode="aspectFit"></image>
      </view>
    </view>

    <view class="summary-strip">
      <view class="summary-item">
        <view class="summary-icon">
          <image class="circle-icon" src="../../images/yaozha/summary-record.png" mode="aspectFit"></image>
        </view>
        <view class="summary-copy">
          <text class="summary-value">{{unitList.length}}</text>
          <text class="summary-label">当前记录</text>
        </view>
      </view>
      <view class="summary-item summary-item-warm">
        <view class="summary-icon summary-icon-warm">
          <image class="circle-icon" src="../../images/yaozha/summary-filter.png" mode="aspectFit"></image>
        </view>
        <view class="summary-copy">
          <text class="summary-value">{{activeFilter}}</text>
          <text class="summary-label">筛选条件</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card filter-panel">
    <view class="filter-tabs">
      <block wx:for="{{filters}}" wx:key="index">
        <view
          class="filter-tab {{activeFilter === item ? 'filter-tab-active' : ''}}"
          bindtap="onFilterChange"
          data-type="{{item}}"
        >
          {{item}}
        </view>
      </block>
    </view>
  </view>

  <view class="action-row">
    <button class="section-card soft-action soft-action-sage action-btn" bindtap="goToStatistics">
      <view class="action-icon">
        <image class="circle-icon" src="../../images/yaozha/action-stats.png" mode="aspectFit"></image>
      </view>
      <text class="action-text">统计查看</text>
    </button>
    <button class="section-card soft-action soft-action-sand action-btn" bindtap="onAddClick">
      <view class="action-icon action-icon-light">
        <image class="circle-icon" src="../../images/yaozha/action-add.png" mode="aspectFit"></image>
      </view>
      <text class="action-text">新增回收</text>
    </button>
  </view>

  <view wx:if="{{unitList.length}}" class="recycle-list">
    <block wx:for="{{unitList}}" wx:key="id">
      <view class="list-card recycle-card" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-top">
          <view class="card-title-wrap">
            <view class="card-badge">
              <image
                class="circle-icon"
                src="{{item.typeLabel === '单位' ? '../../images/yaozha/entity-company.png' : '../../images/yaozha/entity-person.png'}}"
                mode="aspectFit"
              ></image>
            </view>
            <text class="card-title">{{item.name}}</text>
          </view>
          <text class="status-chip {{item.status === '已回收' ? 'status-success' : 'status-pending'}}">{{item.status}}</text>
        </view>
        <view class="info-grid">
          <view class="info-item">
            <text class="info-label">联系人</text>
            <text class="info-value">{{item.contact}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">回收日期</text>
            <text class="info-value">{{item.date}}</text>
          </view>
          <view class="info-item info-item-wide">
            <text class="info-label">地址</text>
            <text class="info-value">{{item.address}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">类型</text>
            <text class="info-value">{{item.typeLabel}}</text>
          </view>
        </view>
        <view class="card-landscape"></view>
      </view>
    </block>
  </view>

  <view wx:else class="section-card empty-state">
    当前筛选下暂无药渣回收记录。
  </view>
</view>
