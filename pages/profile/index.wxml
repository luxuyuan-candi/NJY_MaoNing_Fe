<view class="page-shell profile-page">
  <view class="profile-card profile-hero">
    <view class="avatar">猫</view>
    <view class="profile-copy">
      <text class="section-title">个人中心</text>
      <text class="section-subtitle">维护基础登录信息与联系方式，便于后续业务联系和身份识别。</text>
    </view>
  </view>

  <view class="profile-card form-card">
    <view class="field">
      <text class="field-label">昵称</text>
      <input
        class="field-input"
        placeholder="请输入昵称"
        value="{{profile.nickname}}"
        data-field="nickname"
        bindinput="onInputChange"
      />
    </view>
    <view class="field">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{profile.phone}}"
        data-field="phone"
        bindinput="onInputChange"
      />
    </view>
    <view class="field">
      <text class="field-label">身份说明</text>
      <input
        class="field-input"
        placeholder="例如：教师、学生、志愿者"
        value="{{profile.role}}"
        data-field="role"
        bindinput="onInputChange"
      />
    </view>
    <button class="primary-btn save-btn" bindtap="saveProfile">保存信息</button>
  </view>

  <view class="profile-card tips-card">
    <text class="tips-title">说明</text>
    <text class="tips-text">当前页面以轻量信息维护为主，已保存内容会缓存在本地，方便后续扩展正式登录能力。</text>
  </view>
</view>
