.profile-page {
  background:
    radial-gradient(circle at top left, rgba(239, 229, 214, 0.8), transparent 32%),
    linear-gradient(180deg, #f7f4ef 0%, #f5efe7 100%);
}

.profile-hero,
.form-card,
.tips-card {
  padding: 30rpx;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #345c4a;
  color: #ffffff;
  font-size: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
}

.form-card,
.tips-card {
  margin-top: 22rpx;
}

.field {
  margin-bottom: 26rpx;
}

.field:last-of-type {
  margin-bottom: 32rpx;
}

.field-label,
.tips-title {
  display: block;
  font-size: 24rpx;
  color: #8b7b6f;
}

.field-input {
  margin-top: 12rpx;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f7f3ed;
  color: #2e2a26;
}

.save-btn {
  width: 100%;
}

.tips-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4b433c;
}
