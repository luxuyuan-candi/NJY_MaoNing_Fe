page {
  --bg-color: #f6f3ee;
  --card-color: #fffdf9;
  --border-color: #e7ddd2;
  --text-primary: #2e2a26;
  --text-secondary: #7f7267;
  --accent-color: #345c4a;
  --accent-soft: #e6efe9;
  --warm-soft: #efe5d6;
  background: var(--bg-color);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
}

button {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.section-card,
.list-card,
.profile-card {
  background: var(--card-color);
  border: 1rpx solid var(--border-color);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(63, 46, 28, 0.06);
}

.section-title {
  font-size: 42rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.pill-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pill {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #f3ede4;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.pill-active {
  background: var(--accent-color);
  color: #ffffff;
}

.primary-btn,
.secondary-btn {
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-btn {
  background: var(--accent-color);
  color: #ffffff;
}

.secondary-btn {
  background: var(--accent-soft);
  color: var(--accent-color);
}

.empty-state {
  padding: 56rpx 28rpx;
  text-align: center;
  color: var(--text-secondary);
}
